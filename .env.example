# ============================================
# AI Generative Core — Configuration
# ============================================

# --- App ---
APP_NAME=AI Generative Core
APP_VERSION=0.2.2
DEBUG=true

# --- Ollama (Local LLM) ---
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_TIMEOUT=120
# Ollama Cloud API keys (comma-separated, opsional)
# Dibutuhkan untuk model cloud (glm-5.1:cloud, qwen3.5:397b-cloud, dsb)
# Jika kosong, hanya model lokal yang bisa dipakai
OLLAMA_API_KEYS=

# --- Google Gemini ---
# Multi-key support (comma-separated, prioritas utama)
GEMINI_API_KEYS=
# Single key (backward compatible, dipakai jika GEMINI_API_KEYS kosong)
GEMINI_API_KEY=
GEMINI_TIMEOUT=120

# --- NVIDIA NIM ---
# API key from build.nvidia.com (nvapi-... format)
# Kosongkan untuk skip NVIDIA provider
NVIDIA_API_KEY=
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_TIMEOUT=120

# --- Gateway Auth ---
# Static service token. Frontend harus kirim: Authorization: Bearer <token>
# Kosongkan untuk disable auth (development mode)
GATEWAY_TOKEN=my-secret-gateway-token-2026

# Rate limit: max requests per minute (0 = unlimited)
RATE_LIMIT_RPM=120

# --- Conversation History ---
# Max messages per session (trim FIFO, system prompt preserved)
CHAT_MAX_HISTORY=50
# Session TTL in minutes (auto-expire inactive sessions)
CHAT_SESSION_TTL=30

# --- Logging ---
LOG_LEVEL=DEBUG
LOG_FORMAT=text

# --- Caching ---
CACHE_ENABLED=true
CACHE_TTL=300
CACHE_MAX_SIZE=1000

# --- Health Check ---
HEALTH_CHECK_INTERVAL=30
HEALTH_CHECK_TIMEOUT=5
HEALTH_CHECK_THRESHOLD=3

# --- Batch Processing ---
BATCH_MAX_SIZE=20
BATCH_CONCURRENCY=5
